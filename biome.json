{
    "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": false,
        "includes": ["index.html", "css/**", "js/**"]
    },
    "overrides": [
        {
            "includes": ["js/vendor.colordx.js"],
            "linter": {
                "enabled": false
            },
            "formatter": {
                "enabled": false
            }
        }
    ],
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "suspicious": {
                "noAssignInExpressions": "off"
            },
            "a11y": {
                "noSvgWithoutTitle": "off"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "none"
        }
    },
    "css": {
        "formatter": {
            "enabled": true
        }
    }
}
